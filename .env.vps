# Konfigurasi MySQL VPS (Ganti password ini demi keamanan)
MYSQL_ROOT_PASSWORD=RootSecretVPS123!
MYSQL_DATABASE=ekskul_db
MYSQL_USER=ekskul_user
MYSQL_PASSWORD=UserSecretVPS123!

# URL Database untuk Prisma di dalam container (Merujuk ke service "mysql")
DATABASE_URL="mysql://ekskul_user:UserSecretVPS123!@mysql:3306/ekskul_db"

# Secret Key untuk Next.js/Auth
JWT_SECRET=super-secret-jwt-key-vps-production-min-32-chars
